import os
import sys
from building import *
import rtconfig

SIFLI_SDK = os.getenv('SIFLI_SDK')
cwd = GetCurrentDir()
src = []
CPPPATH = []

# Add our source include path so ElenixOS can find mem_mgr.h, etc.
project_src_inc = os.path.join(cwd, '..', 'src')
if os.path.isdir(project_src_inc):
    CPPPATH += [project_src_inc]
project_src_inc2 = os.path.join(cwd, '..', 'src', 'inc')
if os.path.isdir(project_src_inc2):
    CPPPATH += [project_src_inc2]

# Create a bridge include directory so ElenixOS can use #include "lvgl/src/..."
# by symlinking lvgl -> SDK LVGL root
if SIFLI_SDK:
    lvgl_root = os.path.join(SIFLI_SDK, 'external', 'lvgl_v9')
    if os.path.isdir(lvgl_root):
        bridge_dir = os.path.join(cwd, '..', 'build', 'lvgl_bridge')
        lvgl_link = os.path.join(bridge_dir, 'lvgl')
        if not os.path.exists(lvgl_link):
            try:
                os.makedirs(bridge_dir, exist_ok=True)
                os.symlink(lvgl_root, lvgl_link)
            except Exception as e:
                print("Warning: could not create LVGL symlink: {}".format(e))
        CPPPATH += [bridge_dir]

def collect_sources(base_dir, exts=(".c", ".cpp", ".S", ".s"), exclude_substr=None):
    files = []
    for root, dirs, fnames in os.walk(base_dir):
        for f in fnames:
            ext = os.path.splitext(f)[1]
            if ext in exts:
                rel = os.path.relpath(os.path.join(root, f), cwd)
                if exclude_substr and exclude_substr in rel:
                    continue
                files += Glob(rel)
    return files

def collect_inc(base_dir):
    paths = set()
    for root, dirs, fnames in os.walk(base_dir):
        for f in fnames:
            if os.path.splitext(f)[1] in ('.h', '.hpp'):
                paths.add(os.path.normpath(root))
    return list(paths)

EOS_ROOT = os.path.join(cwd, 'ElenixOS')

# --- ElenixOS core source (exclude files we provide ourselves) ---
src += collect_sources(os.path.join(EOS_ROOT, 'src'),
                       exclude_substr='port/critical/eos_port_critical_rtthread.c')
# Exclude ElenixOS's own jerry_port.c (we provide our own)
src = [s for s in src if 'script_engine/jerry_port.c' not in str(s)]
CPPPATH += collect_inc(os.path.join(EOS_ROOT, 'src'))

# --- ElenixOS resources ---
src += collect_sources(os.path.join(EOS_ROOT, 'resources/font'))
CPPPATH += collect_inc(os.path.join(EOS_ROOT, 'resources'))

# --- cJSON (NOT compiled - SDK provides cJSON-1.7.17 via PKG_USING_CJSON) ---
CPPPATH += [os.path.join(EOS_ROOT, 'third_party/cJSON')]

# --- JerryScript ---
JS_ROOT = os.path.join(EOS_ROOT, 'third_party/jerryscript')
js_src = []
js_src += collect_sources(os.path.join(JS_ROOT, 'jerry-core'))
js_src += collect_sources(os.path.join(JS_ROOT, 'jerry-ext'))
js_src += collect_sources(os.path.join(JS_ROOT, 'jerry-port/common'))
CPPPATH += [os.path.join(JS_ROOT, 'jerry-core/include')]
CPPPATH += [os.path.join(JS_ROOT, 'jerry-ext/include')]
# JerryScript source-internal headers (all dirs with .h files)
CPPPATH += collect_inc(os.path.join(JS_ROOT, 'jerry-core'))
CPPPATH += collect_inc(os.path.join(JS_ROOT, 'jerry-ext'))

# --- RemixIcon ---
RI_ROOT = os.path.join(EOS_ROOT, 'third_party/RemixIcon')
src += collect_sources(RI_ROOT)
CPPPATH += collect_inc(RI_ROOT)

# Force-include config.h for JerryScript by prepending to global CCFLAGS
# This is necessary because the SDK's include path resolution doesn't
# reliably find jerry-core/config.h from jrt.h's #include "config.h"
JS_CONFIG_H = os.path.join(JS_ROOT, 'jerry-core', 'config.h')
try:
    from building import Env
    if os.path.isfile(JS_CONFIG_H):
        Env['CCFLAGS'] = '-include ' + JS_CONFIG_H + ' ' + Env.get('CCFLAGS', '')
except Exception as e:
    print("Warning: config.h override failed: {}".format(e))

def _generate_eos_config_gen(config_path, output_dir):
    """Parse .config from Kconfig and generate eos_config_gen.h.

    Strips the CONFIG_ prefix from every ElenixOS entry in .config and
    outputs a corresponding #define with a #ifndef guard, so that
    rtconfig.h (if force-included first) takes precedence without
    redefinition warnings.

    Choice-type values are handled inside Kconfig itself via companion
    int configs with default ... if cascades — no mapping table needed.
    """
    if not os.path.isfile(config_path):
        return

    lines = [
        '/*',
        ' * Automatically generated from Kconfig .config — DO NOT EDIT.',
        ' */',
        '',
        '#ifndef EOS_CONFIG_GEN_H',
        '#define EOS_CONFIG_GEN_H',
        '',
    ]

    with open(config_path, 'r') as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith('#'):
                continue
            if '=' not in line:
                continue
            key, _, val = line.partition('=')
            key = key.strip()
            val = val.strip()

            if not (key.startswith('CONFIG_EOS_') or key.startswith('CONFIG_ELENIX_')):
                continue

            name = key[7:]   # strip 'CONFIG_'

            if val == 'y':
                lines.append('#ifndef %s' % name)
                lines.append('#define %s 1' % name)
                lines.append('#endif')
            elif val.startswith('"') and val.endswith('"'):
                lines.append('#ifndef %s' % name)
                lines.append('#define %s %s' % (name, val))
                lines.append('#endif')
            else:
                lines.append('#ifndef %s' % name)
                lines.append('#define %s %s' % (name, val))
                lines.append('#endif')

    lines += ['', '#endif /* EOS_CONFIG_GEN_H */', '']

    output = os.path.join(output_dir, 'eos_config_gen.h')
    with open(output, 'w') as f:
        f.write('\n'.join(lines) + '\n')

# Find the build output directory and generate eos_config_gen.h
def _find_build_dir(base_dir):
    """Find the build output directory containing .config."""
    try:
        out = rtconfig.OUTPUT_DIR
        path = os.path.join(base_dir, out)
        if os.path.isfile(os.path.join(path, '.config')):
            return path
    except AttributeError:
        pass
    for name in sorted(os.listdir(base_dir), reverse=True):
        if name.startswith('build_') and os.path.isdir(os.path.join(base_dir, name)):
            path = os.path.join(base_dir, name)
            if os.path.isfile(os.path.join(path, '.config')):
                return path
    return None

def _read_config_val(config_path, key):
    """Read a config value from .config. Returns None if not found."""
    if not os.path.isfile(config_path):
        return None
    with open(config_path, 'r') as f:
        for line in f:
            line = line.strip()
            if line.startswith(key + '='):
                return line.split('=', 1)[1].strip()
            if line == '# ' + key + ' is not set':
                return 'n'
    return None

build_dir = _find_build_dir(os.path.join(cwd, '..'))
ccflags = ''
if build_dir:
    config_path = os.path.join(build_dir, '.config')
    _generate_eos_config_gen(config_path, build_dir)
    CPPPATH += [build_dir]
    # Compiler flags to pass to DefineGroup — these are also set globally
    # in project/SConscript for SDK targets, but explicit for robustness.
    rtconfig_h = os.path.join(build_dir, 'rtconfig.h')
    if os.path.isfile(rtconfig_h):
        ccflags += ' -include ' + rtconfig_h
    if _read_config_val(config_path, 'CONFIG_EOS_OVERRIDE_LVGL_STDLIB_MALLOC_ENABLE') == 'y':
        ccflags += ' -DLV_USE_STDLIB_MALLOC=4'

# Build defines — keep only non-EOS flags that are not covered
# by Kconfig (JerryScript features required by ElenixOS script_engine_init)
CPPDEFINES = [
    'JERRY_VM_HALT=1',
    'JERRY_MEM_STATS=1',
    'JERRY_ERROR_MESSAGES=1',
]

src += js_src

group = DefineGroup(
    'ElenixOS',
    src,
    depend=[],
    CPPPATH=CPPPATH,
    CPPDEFINES=CPPDEFINES,
    CCFLAGS=ccflags,
)

Return('group')
